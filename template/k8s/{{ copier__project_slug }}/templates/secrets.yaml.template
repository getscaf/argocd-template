apiVersion: v1
kind: Secret
metadata:
  name: {{ copier__project_slug }}-secrets
  namespace: {{ copier__project_slug }}-${ENVIRONMENT}
type: Opaque
stringData:
  AWS_S3_ACCESS_KEY_ID: "${AWS_S3_ACCESS_KEY_ID}"
  AWS_S3_SECRET_ACCESS_KEY: "${AWS_S3_SECRET_ACCESS_KEY}"
  DJANGO_SECRET_KEY: "${DJANGO_SECRET_KEY}"
